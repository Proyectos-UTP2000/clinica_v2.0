# Copy to .env and replace placeholders with local/private values.
DB_URL=jdbc:postgresql://localhost:5432/clinica_db
DB_USERNAME=clinica
DB_PASSWORD=change-me

POSTGRES_DB=clinica_db
POSTGRES_USER=clinica
POSTGRES_PASSWORD=change-me

JWT_SECRET=change-me-at-least-32-characters
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGIN=http://localhost:4200

MAIL_FROM=no-reply@clinica.local
MAIL_ENABLED=false
MAIL_USERNAME=change-me@example.com
MAIL_PASSWORD=change-me

API_PERU_URL_DNI=https://miapi.cloud/v1/dni/
API_PERU_TOKEN=change-me

# Reserved for future Web_Pacientes image uploads.
CLOUDINARY_CLOUD_NAME=change-me
CLOUDINARY_API_KEY=change-me
CLOUDINARY_API_SECRET=change-me
